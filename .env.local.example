# Copy this file to .env.local and fill in your values.

# ---- Required ----
# Groq API key. Get one free at https://console.groq.com/keys
GROQ_API_KEY=gsk_your_key_here

# ---- Optional: Redis-backed stores ----
# Leave STORE_BACKEND unset (or "memory") for local dev — stores are
# held in-memory per Node process.
# Set STORE_BACKEND=redis + the two Upstash vars to persist state and
# survive serverless multi-instance hosting (Vercel, etc.). Get a free
# REST token at https://console.upstash.com/.
# STORE_BACKEND=redis
# UPSTASH_REDIS_REST_URL=https://your-db.upstash.io
# UPSTASH_REDIS_REST_TOKEN=your_token_here
